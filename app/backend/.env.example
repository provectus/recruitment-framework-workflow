APP_NAME=backend
DEBUG=false
# Option A: Full connection string (local dev / Docker Compose)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tap
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/tap

# Option B: Decomposed DB vars (ECS / production — DATABASE_URL built automatically)
# DB_HOST=your-rds-host.region.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=tap
# DB_USERNAME=tap_admin
# DB_PASSWORD=your_password_here

# Authentication
# REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=dev-secret-change-in-production
CORS_ORIGINS=["http://localhost:5173"]
COOKIE_DOMAIN=
# Defaults to true; set false only for local HTTP dev
COOKIE_SECURE=false
ALLOWED_EMAIL_DOMAIN=provectus.com

# Cognito OAuth
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=your_client_id_here
COGNITO_CLIENT_SECRET=your_client_secret_here
COGNITO_DOMAIN=your-cognito-domain.auth.us-east-1.amazoncognito.com
COGNITO_REDIRECT_URI=http://localhost:8000/api/auth/callback

# S3 Configuration
S3_BUCKET_NAME=
S3_REGION=us-east-1
# Local dev (MinIO) -- leave unset for production (uses standard AWS endpoints)
S3_ENDPOINT_URL=http://minio:9000
S3_PRESIGN_ENDPOINT_URL=http://localhost:9100
