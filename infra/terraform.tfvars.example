# Terraform Variables Example for Lauter Infrastructure
# Copy this file to terraform.tfvars and fill in actual values
# IMPORTANT: Never commit terraform.tfvars to version control (already in .gitignore)

# AWS region where resources will be deployed
region = "us-east-1"

# Project name used as prefix for resource naming and tagging
project_name = "lauter"

# Environment name (poc, dev, staging, prod)
environment = "poc"

# Team or person responsible for the resources (used in default_tags)
owner = "recruitment-team"

# Custom domain for the application (e.g., lauter.provectus.com)
# Leave empty to deploy without custom domain (uses CloudFront default *.cloudfront.net)
# Required DNS records will need to be created after terraform apply:
# - your-domain.com → CloudFront (serves both SPA and /api/* via path routing)
# - ACM validation CNAME records (output by Terraform)
domain = ""

# GitHub repository in format org/repo for OIDC trust policy
# Used for GitHub Actions CI/CD pipeline authentication
github_repo = "your-org/your-repo"

# ARN of the JWT secret key in AWS Secrets Manager
# Create with: aws secretsmanager create-secret --name lauter/jwt-secret-key --secret-string "$(openssl rand -base64 64)"
jwt_secret_key_arn = "arn:aws:secretsmanager:us-east-1:123456789012:secret:lauter/jwt-secret-key-AbCdEf"

# Google OAuth credentials are stored in Secrets Manager (not in tfvars):
#   lauter/google-oauth/client-id
#   lauter/google-oauth/client-secret
# Create at: https://console.cloud.google.com/ → APIs & Services → Credentials
# Update with: aws secretsmanager put-secret-value --secret-id lauter/google-oauth/client-id --secret-string "your-id"

# Enable Bedrock AI model access for ECS tasks (set true after enabling model access in console)
enable_bedrock = false

# Email address for CloudWatch alarm notifications (leave empty to skip)
alert_email = ""

# Amazon Bedrock model IDs for evaluation Lambda functions
# Ensure these models are enabled in your AWS account via the Bedrock console
# Heavy: screening eval, technical eval, recommendation (complex reasoning)
bedrock_model_id_heavy = "anthropic.claude-sonnet-4-6"
# Light: CV analysis, feedback generation (simpler extraction/generation)
bedrock_model_id_light = "anthropic.claude-haiku-4-5-20251001-v1:0"
